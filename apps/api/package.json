{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec \"tsx --env-file=.env src/index.ts\"",
    "worker": "tsx --env-file=.env src/queue/worker.ts",
    "worker:dev": "nodemon --exec \"tsx --env-file=.env src/queue/worker.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "echo 'lint api'",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ecommerce/shared": "workspace:*",
    "@ecommerce/types": "workspace:*",
    "@hono/node-server": "^1.18.1",
    "@hono/swagger-ui": "^0.6.1",
    "@neondatabase/serverless": "^0.10.4",
    "@paralleldrive/cuid2": "^2.2.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.76.5",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.9.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.2.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.30.4",
    "happy-dom": "^18.0.1",
    "nodemon": "^3.1.10",
    "openapi-types": "^12.1.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
