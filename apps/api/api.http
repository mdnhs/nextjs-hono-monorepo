###############################################
### REVIEW ENDPOINTS
###############################################

### Get Product Reviews (Public)
GET {{baseUrl}}/api/v1/reviews/product/{{productId}}

### Get Product Reviews with Filters
GET {{baseUrl}}/api/v1/reviews/product/{{productId}}?rating=5&verified=true

### Get Product Rating Statistics
GET {{baseUrl}}/api/v1/reviews/product/{{productId}}/stats

### Check if User Can Review Product
GET {{baseUrl}}/api/v1/reviews/product/{{productId}}/can-review
Authorization: Bearer {{authToken}}

### Create Product Review (After purchase)
POST {{baseUrl}}/api/v1/reviews/product/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 5,
  "title": "Excellent product!",
  "comment": "This product exceeded my expectations. Great quality and fast shipping!",
  "images": ["https://example.com/review-image1.jpg"]
}

### Create Review with Order ID (Verified Purchase)
POST {{baseUrl}}/api/v1/reviews/product/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 4,
  "title": "Good but could be better",
  "comment": "The product works well but the packaging could use improvement. Overall satisfied.",
  "orderId": "{{orderId}}"
}

### Update Review (Update reviewId after creating a review)
@reviewId = 
PATCH {{baseUrl}}/api/v1/reviews/{{reviewId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 4,
  "comment": "Updated my review after using the product for a month. Still works great!"
}

### Delete Review
DELETE {{baseUrl}}/api/v1/reviews/{{reviewId}}
Authorization: Bearer {{authToken}}

### Mark Review as Helpful
POST {{baseUrl}}/api/v1/reviews/{{reviewId}}/helpful
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "helpful": true
}

### Mark Review as Not Helpful
POST {{baseUrl}}/api/v1/reviews/{{reviewId}}/helpful
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "helpful": false
}

### Get My Reviews
GET {{baseUrl}}/api/v1/reviews/my
Authorization: Bearer {{authToken}}

###############################################
### REVIEW ERROR TESTING
###############################################

### Test Creating Review Without Purchase
POST {{baseUrl}}/api/v1/reviews/product/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 3,
  "comment": "Never bought this product but reviewing anyway"
}

### Test Invalid Rating
POST {{baseUrl}}/api/v1/reviews/product/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 10,
  "comment": "This rating is invalid - should be between 1 and 5"
}

### Test Short Comment
POST {{baseUrl}}/api/v1/reviews/product/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 3,
  "comment": "Too short"
}

### Test Duplicate Review
POST {{baseUrl}}/api/v1/reviews/product/{{productId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "rating": 4,
  "comment": "Trying to review the same product twice should fail if already reviewed"
}